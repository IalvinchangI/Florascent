{
  "rules": {
    // audience & admin can read all data
    ".read": true, 
    // only admin can write all data
    ".write": "auth != null", 
		
    // the block audience can write
    "voteStatistic": {
      // audience can add new vote
      "$vote_id": {
        ".write": "!data.exists()"
      }
    }
  }
}